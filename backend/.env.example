# Backend env — copy to .env for local dev. Real .env is gitignored.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tipvan_dev?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=4000
PUBLIC_URL="http://localhost:8080"
CORS_ORIGIN="http://localhost:8080"
UPLOAD_DIR="./uploads"
# Stripe (leave STRIPE_SECRET_KEY empty to run in mock mode)
STRIPE_SECRET_KEY=""
STRIPE_SUBSCRIPTION_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""
SUBSCRIPTION_PRICE_GBP=5.49
